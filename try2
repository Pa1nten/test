python
from flask import Flask, render_template, request, redirect, session
import psycopg2

app = Flask(__name__)
app.secret_key = 'tvoi_sekretniy_klyuch'  # Для сессий

# Подключение к БД
def get_db():
    return psycopg2.connect(
        host="localhost",
        database="shop",
        user="postgres",
        password="123"
    )

@app.route('/')
def login_page():
    return render_template('login.html')

@app.route('/auth', methods=['POST'])
def auth():
    login = request.form['login']
    password = request.form['password']

    conn = get_db()
    cur = conn.cursor()
    cur.execute(
        "SELECT id, role, full_name FROM users WHERE login=%s AND password=%s",
        (login, password)
    )
    user = cur.fetchone()
    cur.close()
    conn.close()

    if user:
        session['user_id'] = user[0]
        session['role'] = user[1]
        session['full_name'] = user[2]
        return redirect('/dashboard')
    else:
        return "Ошибка входа", 401

@app.route('/guest')
def guest_view():
    session['role'] = 'guest'
    session['full_name'] = 'Гость'
    return redirect('/products')

@app.route('/products')
def show_products():
    conn = get_db()
    cur = conn.cursor()
    cur.execute("""
        SELECT p.name, p.price, p.discount, p.stock, p.image,
               c.name as category, b.name as brand
        FROM products p
        LEFT JOIN categories c ON p.category_id = c.id
        LEFT JOIN brands b ON p.brand_id = b.id
    """)
    products = cur.fetchall()
    cur.close()
    conn.close()

    return render_template('products.html',
                         products=products,
                         user_role=session.get('role', 'guest'),
                         user_name=session.get('full_name', 'Гость'))

@app.route('/logout')
def logout():
    session.clear()
    return redirect('/')

if __name__ == '__main__':
    app.run(debug=True)

