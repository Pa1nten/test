Шпаргалка-памятка (повесь рядом):
Действие	Команда
Создать БД	CREATE DATABASE имя;
Создать таблицу	CREATE TABLE имя (поле ТИП, ...);
Удалить таблицу	DROP TABLE имя CASCADE;
Вставить данные	INSERT INTO имя VALUES(...);
Выбрать данные	SELECT * FROM имя WHERE ...;
Обновить	UPDATE имя SET поле=значение WHERE ...;
Удалить	DELETE FROM имя WHERE ...;
Добавить внешний ключ	ALTER TABLE ADD CONSTRAINT fk... FOREIGN KEY...
Создать индекс	CREATE INDEX idx_... ON имя(поле);
Дать права	GRANT SELECT ON имя TO пользователь;
