{% extends "base.html" %}

{% block title %}Товары{% endblock %}

{% block content %}
<h1>Каталог обуви</h1>

<!-- Панель фильтрации (видна всем) -->
<div class="filter-panel">
    <form method="GET" action="{{ url_for('products') }}">
        <div class="filter-row">
            <input type="text" name="search" placeholder="Поиск..." value="{{ request.args.get('search', '') }}">

            <select name="category">
                <option value="">Все категории</option>
                {% for cat in categories %}
                <option value="{{ cat.id }}" {% if request.args.get('category')|string == cat.id|string %}selected{% endif %}>
                    {{ cat.name }}
                </option>
                {% endfor %}
            </select>

            <select name="sort">
                <option value="name">По названию</option>
                <option value="price">По цене</option>
                <option value="discount">По скидке</option>
                <option value="stock">По остатку</option>
            </select>

            <button type="submit" class="btn btn-primary">Применить</button>
            <a href="{{ url_for('products') }}" class="btn">Сбросить</a>
        </div>
    </form>
</div>

<!-- Кнопки для админа -->
{% if session.role == 'admin' %}
<div class="admin-actions">
    <a href="{{ url_for('add_product') }}" class="btn btn-success">➕ Добавить товар</a>
</div>
{% endif %}

<!-- ТАБЛИЦА ТОВАРОВ -->
<table class="products-table">
    <thead>
        <tr>
            <th>Фото</th>
            <th>Артикул</th>
            <th>Наименование</th>
            <th>Категория</th>
            <th>Цена</th>
            <th>Скидка</th>
            <th>Остаток</th>
            {% if session.role == 'admin' %}
            <th>Действия</th>
            {% endif %}
        </tr>
    </thead>
    <tbody>
        {% for product in products %}
        <!-- ПОДСВЕТКА СТРОК ПО ЗАДАНИЮ -->
        <tr class="
            {% if product.stock == 0 %}row-out-of-stock
            {% elif product.discount > 15 %}row-high-discount
            {% endif %}
        ">
            <td class="product-image-cell">
                <img src="{{ url_for('static', filename='images/' + product.image_url) if product.image_url else url_for('static', filename='picture.png') }}"
                     class="product-image"
                     onerror="this.src='{{ url_for('static', filename='picture.png') }}'">
            </td>
            <td>{{ product.article }}</td>
            <td>{{ product.name }}</td>
            <td>{{ product.category_name or '-' }}</td>
            <td class="price-cell">
                {% if product.discount > 0 %}
                    <span class="old-price">{{ product.price }} руб.</span>
                    <span class="new-price">{{ (product.price * (100 - product.discount) / 100)|round(2) }} руб.</span>
                {% else %}
                    {{ product.price }} руб.
                {% endif %}
            </td>
            <td>
                {% if product.discount > 0 %}
                    <span class="discount-badge">{{ product.discount }}%</span>
                {% else %}
                    -
                {% endif %}
            </td>
            <td>
                {% if product.stock > 0 %}
                    {{ product.stock }} {{ product.unit }}
                {% else %}
                    <span class="out-of-stock-label">Нет в наличии</span>
                {% endif %}
            </td>
            {% if session.role == 'admin' %}
            <td class="action-buttons">
                <a href="{{ url_for('edit_product', product_id=product.id) }}" class="btn-edit">✏️</a>
                <a href="{{ url_for('delete_product', product_id=product.id) }}" class="btn-delete"
                   onclick="return confirm('Удалить товар?')">🗑️</a>
            </td>
            {% endif %}
        </tr>
        {% else %}
        <tr>
            <td colspan="{% if session.role == 'admin' %}8{% else %}7{% endif %}" class="no-data">
                Товары не найдены
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
