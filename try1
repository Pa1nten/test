{% extends "base.html" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<h1>{{ title }}</h1>

<form method="POST" class="product-form">
    <div class="form-grid">
        <div class="form-group">
            <label>Артикул *</label>
            <input type="text" name="article" value="{{ product.article if product else '' }}" required>
        </div>

        <div class="form-group">
            <label>Название *</label>
            <input type="text" name="name" value="{{ product.name if product else '' }}" required>
        </div>

        <div class="form-group full-width">
            <label>Описание</label>
            <textarea name="description" rows="3">{{ product.description if product else '' }}</textarea>
        </div>

        <div class="form-group">
            <label>Категория</label>
            <select name="category_id">
                <option value="">-- Выберите --</option>
                {% for cat in categories %}
                <option value="{{ cat.id }}" {% if product and product.category_id == cat.id %}selected{% endif %}>
                    {{ cat.name }}
                </option>
                {% endfor %}
            </select>
        </div>

        <div class="form-group">
            <label>Производитель</label>
            <select name="brand_id">
                <option value="">-- Выберите --</option>
                {% for brand in brands %}
                <option value="{{ brand.id }}" {% if product and product.brand_id == brand.id %}selected{% endif %}>
                    {{ brand.name }}
                </option>
                {% endfor %}
            </select>
        </div>

        <div class="form-group">
            <label>Цена *</label>
            <input type="number" name="price" step="0.01" value="{{ product.price if product else '' }}" required>
        </div>

        <div class="form-group">
            <label>Скидка (%)</label>
            <input type="number" name="discount" step="1" value="{{ product.discount if product else 0 }}">
        </div>

        <div class="form-group">
            <label>Остаток</label>
            <input type="number" name="stock" value="{{ product.stock if product else 0 }}">
        </div>

        <div class="form-group">
            <label>Единица измерения</label>
            <input type="text" name="unit" value="{{ product.unit if product else 'шт' }}">
        </div>

        <div class="form-group">
            <label>URL фото</label>
            <input type="text" name="image_url" value="{{ product.image_url if product else '' }}">
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a href="{{ url_for('products') }}" class="btn">Отмена</a>
    </div>
</form>
{% endblock %}
