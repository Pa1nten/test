import psycopg2
import psycopg2.extras

# Конфигурация подключения (ЗАПОЛНИ СВОИМИ ДАННЫМИ)
DB_CONFIG = {
    'host': 'localhost',      # или IP сервера
    'port': 5432,             # порт PostgreSQL по умолчанию
    'database': 'shop_db',    # имя твоей БД
    'user': 'postgres',       # твой логин
    'password': '123'         # твой пароль
}

def get_db_connection():
    """Создает и возвращает соединение с БД"""
    conn = psycopg2.connect(**DB_CONFIG)
    return conn

def get_db_cursor(conn, dict_cursor=True):
    """Возвращает курсор (словарь или кортеж)"""
    if dict_cursor:
        return conn.cursor(cursor_factory=psycopg2.extras.DictCursor)
    return conn.cursor()

# Пример использования
if __name__ == '__main__':
    conn = get_db_connection()
    cur = get_db_cursor(conn)
    cur.execute("SELECT version()")
    print(cur.fetchone())
    cur.close()
    conn.close()
